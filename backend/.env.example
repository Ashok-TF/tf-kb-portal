# ============================================================================
# tfGPT KB Portal - Backend configuration
# Copy this file to ".env" and adjust. Everything below has safe defaults so
# the app runs locally with NO external accounts/keys.
# ============================================================================

# --- App ---
APP_NAME="tfGPT KB Portal"
# Comma-separated list of allowed frontend origins (CORS)
CORS_ORIGINS="http://localhost:3001,http://localhost:3000"

# --- Auth (simple placeholder login) ---
# A single shared credential for now. Swap for real SSO later.
KB_PORTAL_USER="admin@thoughtfocus.com"
KB_PORTAL_PASSWORD="tfKB@123"
# Secret used to sign session tokens. CHANGE THIS in any real deployment.
SECRET_KEY="change-me-in-production-please"

# --- Database ---
# Default: local SQLite file. For Postgres use e.g.:
# DATABASE_URL="postgresql+psycopg://user:pass@host:5432/dbname"
DATABASE_URL="sqlite:///./data/kb_portal.db"

# --- Storage ---
# Where uploaded files + the local vector index are kept.
DATA_DIR="./data"

# --- Embeddings ---
# "fake"   = offline lexical embedder, no keys needed (good for dev/demo)
# "openai" = real semantic embeddings (requires OPENAI_API_KEY)
EMBEDDING_PROVIDER="fake"
EMBEDDING_DIM="512"                       # used by the "fake" provider
OPENAI_API_KEY=""
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"   # dim 1536

# --- Vector store ---
# "local"    = JSON file on disk + cosine search, no keys needed (dev/demo)
# "pinecone" = Pinecone managed vector DB (requires PINECONE_API_KEY)
VECTOR_STORE="local"
PINECONE_API_KEY=""
PINECONE_INDEX="tfgpt-kb"
PINECONE_CLOUD="aws"
PINECONE_REGION="us-east-1"

# --- Chunking ---
CHUNK_SIZE="900"        # characters per chunk
CHUNK_OVERLAP="150"     # character overlap between chunks
